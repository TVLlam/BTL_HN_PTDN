<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_danh_gia_kpi_tree" model="ir.ui.view">
            <field name="name">danh_gia_kpi.tree</field>
            <field name="model">danh_gia_kpi</field>
            <field name="arch" type="xml">
                <tree decoration-success="xep_loai in ('xuat_sac','tot')" decoration-warning="xep_loai=='trung_binh'" decoration-danger="xep_loai=='yeu'">
                    <field name="ma_danh_gia"/>
                    <field name="nhan_vien_id"/>
                    <field name="don_vi_id"/>
                    <field name="ky_danh_gia"/>
                    <field name="nam"/>
                    <field name="diem_trung_binh"/>
                    <field name="xep_loai" widget="badge" decoration-success="xep_loai in ('xuat_sac','tot')" decoration-warning="xep_loai in ('trung_binh','kha')" decoration-danger="xep_loai=='yeu'"/>
                    <field name="trang_thai" widget="badge"/>
                </tree>
            </field>
        </record>

        <record id="view_danh_gia_kpi_form" model="ir.ui.view">
            <field name="name">danh_gia_kpi.form</field>
            <field name="model">danh_gia_kpi</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_gui_duyet" string="Gửi duyệt" type="object" class="btn-primary" attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                        <button name="action_hoan_thanh" string="Hoàn thành" type="object" class="btn-success" attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                        <field name="trang_thai" widget="statusbar" statusbar_visible="nhap,cho_duyet,hoan_thanh"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="ma_danh_gia"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="nhan_vien_id"/>
                                <field name="don_vi_id"/>
                                <field name="nguoi_danh_gia_id"/>
                            </group>
                            <group>
                                <field name="ky_danh_gia"/>
                                <field name="quy" attrs="{'invisible': [('ky_danh_gia', '!=', 'quy')]}"/>
                                <field name="thang" attrs="{'invisible': [('ky_danh_gia', '!=', 'thang')]}"/>
                                <field name="nam"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Chấm điểm KPI">
                                <group>
                                    <group>
                                        <field name="hoan_thanh_cong_viec" widget="radio"/>
                                        <field name="chat_luong" widget="radio"/>
                                        <field name="sang_tao" widget="radio"/>
                                    </group>
                                    <group>
                                        <field name="lam_viec_nhom" widget="radio"/>
                                        <field name="ky_luat" widget="radio"/>
                                    </group>
                                </group>
                                <group string="Kết quả">
                                    <field name="diem_trung_binh"/>
                                    <field name="xep_loai"/>
                                </group>
                            </page>
                            <page string="Nhận xét">
                                <group>
                                    <field name="nhan_xet_nhan_vien" placeholder="Nhân viên tự nhận xét về kết quả công việc..."/>
                                    <field name="nhan_xet_quan_ly" placeholder="Quản lý nhận xét, đánh giá..."/>
                                    <field name="muc_tieu_ky_toi" placeholder="Mục tiêu cho kỳ đánh giá tiếp theo..."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_danh_gia_kpi_search" model="ir.ui.view">
            <field name="name">danh_gia_kpi.search</field>
            <field name="model">danh_gia_kpi</field>
            <field name="arch" type="xml">
                <search>
                    <field name="nhan_vien_id"/>
                    <field name="xep_loai"/>
                    <filter name="xuat_sac" string="Xuất sắc" domain="[('xep_loai','=','xuat_sac')]"/>
                    <filter name="yeu" string="Yếu" domain="[('xep_loai','=','yeu')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Xếp loại" name="group_xl" context="{'group_by': 'xep_loai'}"/>
                        <filter string="Phòng ban" name="group_dv" context="{'group_by': 'don_vi_id'}"/>
                        <filter string="Năm" name="group_nam" context="{'group_by': 'nam'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_danh_gia_kpi" model="ir.actions.act_window">
            <field name="name">Đánh giá KPI</field>
            <field name="res_model">danh_gia_kpi</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_danh_gia_kpi_search"/>
        </record>

        <!-- Sequence -->
        <record id="seq_danh_gia_kpi" model="ir.sequence">
            <field name="name">Đánh giá KPI</field>
            <field name="code">danh_gia_kpi</field>
            <field name="prefix">KPI-</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
