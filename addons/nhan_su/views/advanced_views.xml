<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== -->
    <!-- LỊCH NGHỈ PHÉP       -->
    <!-- ===================== -->
    <record id="view_nghi_phep_calendar" model="ir.ui.view">
        <field name="name">nghi_phep.calendar</field>
        <field name="model">nghi_phep</field>
        <field name="arch" type="xml">
            <calendar string="Lịch nghỉ phép"
                      date_start="ngay_bat_dau"
                      date_stop="ngay_ket_thuc"
                      color="loai_nghi"
                      mode="month"
                      event_open_popup="true"
                      quick_add="false">
                <field name="nhan_vien_id"/>
                <field name="loai_nghi"/>
                <field name="so_ngay"/>
                <field name="trang_thai"/>
            </calendar>
        </field>
    </record>

    <record id="action_nghi_phep_calendar" model="ir.actions.act_window">
        <field name="name">Lịch nghỉ phép</field>
        <field name="res_model">nghi_phep</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="context">{'default_loai_nghi': 'phep_nam'}</field>
    </record>

    <!-- ===================== -->
    <!-- PIVOT BẢNG LƯƠNG      -->
    <!-- ===================== -->
    <record id="view_bang_luong_pivot" model="ir.ui.view">
        <field name="name">bang_luong.pivot</field>
        <field name="model">bang_luong</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích lương">
                <field name="don_vi_id" type="row"/>
                <field name="thang" type="col"/>
                <field name="tong_thu_nhap" type="measure"/>
                <field name="thuc_linh" type="measure"/>
                <field name="tong_bao_hiem_nld" type="measure"/>
                <field name="thue_tncn" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_bang_luong_graph_bar" model="ir.ui.view">
        <field name="name">bang_luong.graph</field>
        <field name="model">bang_luong</field>
        <field name="arch" type="xml">
            <graph string="Biểu đồ lương" type="bar">
                <field name="don_vi_id"/>
                <field name="thuc_linh" type="measure"/>
                <field name="tong_thu_nhap" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_bang_luong_pivot" model="ir.actions.act_window">
        <field name="name">Phân tích lương</field>
        <field name="res_model">bang_luong</field>
        <field name="view_mode">pivot,graph,tree,form</field>
    </record>

    <!-- ===================== -->
    <!-- LỊCH ĐÀO TẠO         -->
    <!-- ===================== -->
    <record id="view_dao_tao_calendar" model="ir.ui.view">
        <field name="name">dao_tao.calendar</field>
        <field name="model">dao_tao</field>
        <field name="arch" type="xml">
            <calendar string="Lịch đào tạo"
                      date_start="ngay_bat_dau"
                      date_stop="ngay_ket_thuc"
                      color="loai_dao_tao"
                      mode="month"
                      event_open_popup="true">
                <field name="ten_chuong_trinh"/>
                <field name="loai_dao_tao"/>
                <field name="trang_thai"/>
            </calendar>
        </field>
    </record>

    <record id="action_dao_tao_calendar" model="ir.actions.act_window">
        <field name="name">Lịch đào tạo</field>
        <field name="res_model">dao_tao</field>
        <field name="view_mode">calendar,tree,form</field>
    </record>

    <!-- ===================== -->
    <!-- PIVOT ĐÁNH GIÁ KPI    -->
    <!-- ===================== -->
    <record id="view_danh_gia_kpi_pivot" model="ir.ui.view">
        <field name="name">danh_gia_kpi.pivot</field>
        <field name="model">danh_gia_kpi</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích KPI">
                <field name="don_vi_id" type="row"/>
                <field name="ky_danh_gia" type="col"/>
                <field name="diem_trung_binh" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_danh_gia_kpi_graph" model="ir.ui.view">
        <field name="name">danh_gia_kpi.graph</field>
        <field name="model">danh_gia_kpi</field>
        <field name="arch" type="xml">
            <graph string="Biểu đồ KPI" type="bar">
                <field name="don_vi_id"/>
                <field name="diem_trung_binh" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_danh_gia_kpi_analysis" model="ir.actions.act_window">
        <field name="name">Phân tích KPI</field>
        <field name="res_model">danh_gia_kpi</field>
        <field name="view_mode">pivot,graph,tree,form</field>
    </record>

</odoo>
